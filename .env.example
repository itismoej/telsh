# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELSH_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-1234567890

# Comma-separated list of Telegram user IDs allowed to use the bot.
# Get your ID by messaging @userinfobot on Telegram.
TELSH_ALLOWED_USERS=123456789,987654321

# ── Optional ──────────────────────────────────────────────────────────────────

# Shell to use for sessions (default: /bin/bash).
# For full SSH-like root access to the HOST filesystem, use nsenter to break
# into the host's namespaces (requires privileged: true and pid: host in compose):
# TELSH_SHELL=/usr/bin/nsenter -t 1 -m -u -i -n -p -- /bin/bash
# TELSH_SHELL=/bin/bash

# Idle session timeout in minutes (default: 30)
# TELSH_SESSION_TIMEOUT=30
